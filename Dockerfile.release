# Minimal release image for CI multi-arch builds.
# Expects a pre-built musl binary at ./chordsketch-${TARGETARCH}.
# Used by .github/workflows/docker.yml.

# Pinned to a specific Alpine point release AND its sha256 manifest list
# digest (was floating `alpine:3`) so a future Alpine 3.x change to
# `adduser` flags / musl ABI / or a tag republish cannot silently change
# the image we ship. The tag is kept alongside the digest so Dependabot
# can correlate the bump and humans can read the version at a glance.
# Bump intentionally via Dependabot. See #1070, #1100.
FROM alpine:3.23.3@sha256:25109184c71bdad752c8312a8623239686a9a2071e8825f20acb8f2198c3f659

RUN adduser -D -u 1000 chordsketch

ARG TARGETARCH
COPY chordsketch-${TARGETARCH} /usr/local/bin/chordsketch
RUN chmod +x /usr/local/bin/chordsketch
USER chordsketch

ENTRYPOINT ["/usr/local/bin/chordsketch"]
